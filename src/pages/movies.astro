---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { buildWatchUrls } from "../utils/watch-sites";

const allMovies = await getCollection("movies");
const movies = allMovies.sort((a, b) => b.data.popularity! - a.data.popularity!);

const allGenres = [...new Set(movies.flatMap((m) => m.data.genre))].sort();
const avgRating = (movies.reduce((s, m) => s + (m.data.rating || 0), 0) / movies.length).toFixed(1);
const heroMovie = movies[Math.floor(Math.random() * movies.length)];

const ratingLevels = [
  { label: "全部评分", min: 0 },
  { label: "9.0+", min: 9 },
  { label: "8.5+", min: 8.5 },
  { label: "8.0+", min: 8 },
];
const popularityLevels = [
  { label: "全部热度", min: 0 },
  { label: "95+", min: 95 },
  { label: "90+", min: 90 },
  { label: "85+", min: 85 },
];

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="电影推荐 - 米奇妙妙屋">
  <!-- Cinematic Hero -->
  <div
    class="movies-hero"
    style={`--hero-backdrop: url(${heroMovie.data.backdrop || heroMovie.data.poster})`}
  >
    <div class="movies-hero-overlay"></div>
    <div class="movies-hero-content">
      <h1 class="movies-hero-title">电影推荐</h1>
      <p class="movies-hero-subtitle">
        精心挑选的观影指南，涵盖科幻、剧情、动画、动作、悬疑等多个类型。
        每部电影都值得花上两小时。
      </p>
      <div class="movies-hero-stats">
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{movies.length}</span>
          <span class="movies-hero-stat-label">收录电影</span>
        </div>
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{allGenres.length}</span>
          <span class="movies-hero-stat-label">覆盖类型</span>
        </div>
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{avgRating}</span>
          <span class="movies-hero-stat-label">平均评分</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="movies-filters">
    <!-- Genre Filter -->
    <div class="filter-group">
      <span class="filter-label">类型</span>
      <div class="filter-tabs" id="genreFilter">
        <button class="filter-tab active" data-genre="all">全部</button>
        {allGenres.map((g) => (
          <button class="filter-tab" data-genre={g}>{g}</button>
        ))}
      </div>
    </div>

    <!-- Rating & Popularity Filters -->
    <div class="filter-row">
      <div class="filter-group">
        <span class="filter-label">评分</span>
        <div class="filter-tabs" id="ratingFilter">
          {ratingLevels.map((r) => (
            <button class="filter-tab" class:list={["filter-tab", { active: r.min === 0 }]} data-rating={r.min}>
              {r.label}
            </button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">热度</span>
        <div class="filter-tabs" id="popularityFilter">
          {popularityLevels.map((p) => (
            <button class="filter-tab" class:list={["filter-tab", { active: p.min === 0 }]} data-popularity={p.min}>
              {p.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Active Filter Summary -->
    <div class="filter-summary" id="filterSummary">
      共 <strong id="filterCount">{movies.length}</strong> 部电影
    </div>
  </div>

  <!-- Movie Grid -->
  <div class="movie-grid" id="movieGrid">
    {movies.map((movie, i) => (
      <div
        class="movie-card"
        data-genres={movie.data.genre.join(",")}
        data-rating={movie.data.rating || 0}
        data-popularity={movie.data.popularity || 0}
        style={`--card-delay: ${i * 0.04}s`}
      >
        <a href={`${base}/movies/${movie.id}`} class="movie-card-poster">
          <img
            src={movie.data.poster}
            alt={movie.data.title}
            loading="eager"
            onerror="this.style.display='none'"
          />
          <div class="movie-card-overlay">
            <div class="movie-card-rating">
              {movie.data.rating ? movie.data.rating.toFixed(1) : "N/A"}
            </div>
          </div>
        </a>
        <div class="movie-card-info">
          <h3 class="movie-card-title">
            <a href={`${base}/movies/${movie.id}`}>{movie.data.title}</a>
          </h3>
          <div class="movie-card-meta">
            <span>{movie.data.year}</span>
            <span class="meta-dot"></span>
            <span>{movie.data.director}</span>
          </div>
          <div class="movie-card-genres">
            {movie.data.genre.map((g) => (
              <span class="movie-genre-tag">{g}</span>
            ))}
          </div>
        </div>
        {
          (() => {
            const watchSites: string[] = movie.data.watchLinks || [];
            const links = buildWatchUrls(movie.data.title, watchSites);
            return links.length > 0 ? (
              <button
                class="movie-watch-btn"
                data-title={movie.data.title}
                data-links={JSON.stringify(links)}
              >
                观看
              </button>
            ) : null;
          })()
        }
      </div>
    ))}
  </div>

  <!-- Empty State -->
  <div class="movies-empty" id="moviesEmpty" style="display:none">
    <p>没有匹配的电影，试试调整筛选条件</p>
  </div>
</BaseLayout>

<!-- Watch Modal -->
<div class="watch-modal" id="watchModal">
  <div class="watch-modal-backdrop" id="watchModalBackdrop"></div>
  <div class="watch-modal-content">
    <h3 id="watchModalTitle"></h3>
    <div class="watch-modal-links" id="watchModalLinks"></div>
    <button class="watch-modal-close" id="watchModalClose">关闭</button>
  </div>
</div>

<script>
  // --- Filter Logic ---
  let activeGenre = "all";
  let activeRating = 0;
  let activePopularity = 0;

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>(".movie-card");
    let count = 0;

    cards.forEach((card) => {
      const genres = card.dataset.genres?.split(",") || [];
      const rating = parseFloat(card.dataset.rating || "0");
      const popularity = parseFloat(card.dataset.popularity || "0");

      const genreMatch = activeGenre === "all" || genres.includes(activeGenre);
      const ratingMatch = rating >= activeRating;
      const popularityMatch = popularity >= activePopularity;

      if (genreMatch && ratingMatch && popularityMatch) {
        card.classList.remove("hidden");
        count++;
      } else {
        card.classList.add("hidden");
      }
    });

    const grid = document.getElementById("movieGrid")!;
    const empty = document.getElementById("moviesEmpty")!;
    const countEl = document.getElementById("filterCount")!;

    grid.style.display = count === 0 ? "none" : "";
    empty.style.display = count === 0 ? "" : "none";
    countEl.textContent = String(count);
  }

  function setActiveTab(groupId: string, btn: HTMLButtonElement) {
    document.querySelectorAll<HTMLButtonElement>(`#${groupId} .filter-tab`).forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
  }

  document.getElementById("genreFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("genreFilter", btn);
    activeGenre = btn.dataset.genre || "all";
    applyFilters();
  });

  document.getElementById("ratingFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("ratingFilter", btn);
    activeRating = parseFloat(btn.dataset.rating || "0");
    applyFilters();
  });

  document.getElementById("popularityFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("popularityFilter", btn);
    activePopularity = parseFloat(btn.dataset.popularity || "0");
    applyFilters();
  });

  // --- Watch Modal ---
  function openWatchModal(btn: HTMLButtonElement) {
    const title = btn.dataset.title || "";
    const links = JSON.parse(btn.dataset.links || "[]") as { name: string; url: string }[];

    document.getElementById("watchModalTitle")!.textContent = `观看：${title}`;

    const linksContainer = document.getElementById("watchModalLinks")!;
    linksContainer.innerHTML = links
      .map(
        (l) =>
          `<a href="${l.url}" target="_blank" rel="noopener noreferrer" class="watch-link-btn">${l.name}</a>`
      )
      .join("");

    document.getElementById("watchModal")!.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeWatchModal() {
    document.getElementById("watchModal")!.classList.remove("open");
    document.body.style.overflow = "";
  }

  // Delegate watch button clicks
  document.getElementById("movieGrid")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".movie-watch-btn");
    if (btn) {
      e.preventDefault();
      openWatchModal(btn);
    }
  });

  // Modal close handlers
  document.getElementById("watchModalBackdrop")!.addEventListener("click", closeWatchModal);
  document.getElementById("watchModalClose")!.addEventListener("click", closeWatchModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeWatchModal();
  });

  // --- Intersection Observer for lazy card animation ---
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
  );

  document.querySelectorAll(".movie-card").forEach((card) => observer.observe(card));
</script>

<style is:global>
  /* ===== Movies Hero ===== */
  .movies-hero {
    position: relative;
    margin: -2rem -3rem 2rem;
    padding: 5rem 3rem 4rem;
    background-image: var(--hero-backdrop);
    background-size: cover;
    background-position: center 30%;
    overflow: hidden;
  }

  .movies-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.6) 50%,
      rgba(0, 0, 0, 0.8) 100%
    );
    z-index: 1;
  }

  .movies-hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  .movies-hero-title {
    font-size: 3rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

  .movies-hero-subtitle {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .movies-hero-stats {
    display: flex;
    gap: 2.5rem;
  }

  .movies-hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .movies-hero-stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #f59e0b;
  }

  .movies-hero-stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ===== Filters ===== */
  .movies-filters {
    margin-bottom: 2rem;
  }

  .filter-group {
    margin-bottom: 0.75rem;
  }

  .filter-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .filter-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-tab {
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    white-space: nowrap;
  }

  .filter-tab:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-tab.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .filter-summary {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
  }

  .filter-summary strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* ===== Movie Grid ===== */
  .movie-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .movie-card {
    position: relative;
    border-radius: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.35s ease;
    opacity: 0;
    transform: translateY(20px);
  }

  .movie-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease var(--card-delay),
                transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) var(--card-delay),
                box-shadow 0.35s ease;
  }

  .movie-card.hidden {
    display: none;
  }

  .movie-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    z-index: 5;
  }

  .movie-card-poster {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    aspect-ratio: 2/3;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1b1e 0%, #25262b 50%, #1a1b1e 100%);
  }

  .movie-card-poster::before {
    content: "🎬";
    font-size: 2.5rem;
    position: absolute;
    opacity: 0.3;
    z-index: 0;
  }

  .movie-card-poster img {
    position: relative;
    z-index: 1;
  }

  .movie-card-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .movie-card:hover .movie-card-poster img {
    transform: scale(1.08);
  }

  .movie-card-overlay {
    position: absolute;
    top: 0;
    right: 0;
    padding: 0.5rem;
  }

  .movie-card-rating {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    box-shadow: 0 2px 12px rgba(245, 158, 11, 0.4);
  }

  .movie-card-info {
    padding: 0.75rem;
  }

  .movie-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .movie-card-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.15s;
  }

  .movie-card-title a:hover {
    color: var(--accent);
  }

  .movie-card-meta {
    font-size: 0.72rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 0.4rem;
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .movie-card-genres {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .movie-genre-tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-text);
  }

  .movie-watch-btn {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    border: none;
    background: var(--accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.25s ease;
    font-family: inherit;
  }

  .movie-card:hover .movie-watch-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .movie-watch-btn:hover {
    background: #f59e0b;
    box-shadow: 0 4px 16px rgba(245, 158, 11, 0.4);
  }

  /* ===== Watch Modal ===== */
  .watch-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .watch-modal.open {
    opacity: 1;
    pointer-events: auto;
  }

  .watch-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .watch-modal-content {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    min-width: 320px;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    text-align: center;
    animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes modalIn {
    from {
      opacity: 0;
      transform: scale(0.9) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .watch-modal-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  .watch-modal-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .watch-link-btn {
    display: block;
    padding: 0.7rem 1rem;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .watch-link-btn:hover {
    background: #f59e0b;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .watch-modal-close {
    padding: 0.4rem 1.2rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .watch-modal-close:hover {
    background: var(--hover);
  }

  /* ===== Empty State ===== */
  .movies-empty {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* ===== Responsive ===== */
  @media (max-width: 1200px) {
    .movie-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .movie-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .movies-hero {
      margin: -2rem -1.5rem 2rem;
      padding: 3rem 1.5rem 2.5rem;
    }
    .movies-hero-title {
      font-size: 2.2rem;
    }
  }

  @media (max-width: 768px) {
    .movies-hero {
      margin: -1rem -1rem 1.5rem;
      padding: 2.5rem 1rem 2rem;
      border-radius: 0;
    }
    .movies-hero-title {
      font-size: 1.8rem;
    }
    .movies-hero-subtitle {
      font-size: 0.9rem;
    }
    .movies-hero-stats {
      gap: 1.5rem;
    }
    .movies-hero-stat-value {
      font-size: 1.5rem;
    }
    .filter-row {
      flex-direction: column;
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .movie-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
  }
</style>
