---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { buildWatchUrls } from "../utils/watch-sites";

const allMovies = await getCollection("movies");

// Separate recommendations (recommend/ dir) from curated collection
const recommendMovies = allMovies
  .filter((m) => m.id.startsWith("recommend/"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const movies = allMovies
  .filter((m) => !m.id.startsWith("recommend/"))
  .sort((a, b) => b.data.popularity! - a.data.popularity!);

const allGenres = [...new Set(movies.flatMap((m) => m.data.genre))].sort();
const avgRating = (movies.reduce((s, m) => s + (m.data.rating || 0), 0) / movies.length).toFixed(1);
const heroMovie = movies[Math.floor(Math.random() * movies.length)];

const ratingLevels = [
  { label: "全部评分", min: 0 },
  { label: "9.0+", min: 9 },
  { label: "8.5+", min: 8.5 },
  { label: "8.0+", min: 8 },
];
const popularityLevels = [
  { label: "全部热度", min: 0 },
  { label: "95+", min: 95 },
  { label: "90+", min: 90 },
  { label: "85+", min: 85 },
];

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="电影推荐 - 米奇妙妙屋">
  <!-- Cinematic Hero -->
  <div
    class="movies-hero"
    style={`--hero-backdrop: url(${heroMovie.data.backdrop || heroMovie.data.poster})`}
  >
    <div class="movies-hero-overlay"></div>
    <div class="movies-hero-content">
      <h1 class="movies-hero-title">电影推荐</h1>
      <p class="movies-hero-subtitle">
        精心挑选的观影指南，涵盖科幻、剧情、动画、动作、悬疑等多个类型。
        每部电影都值得花上两小时。
      </p>
      <div class="movies-hero-stats">
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{movies.length}</span>
          <span class="movies-hero-stat-label">收录电影</span>
        </div>
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{allGenres.length}</span>
          <span class="movies-hero-stat-label">覆盖类型</span>
        </div>
        <div class="movies-hero-stat">
          <span class="movies-hero-stat-value">{avgRating}</span>
          <span class="movies-hero-stat-label">平均评分</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommendation Strip -->
  {recommendMovies.length > 0 && (
    <section class="recommend-section" id="recommendSection">
      <div class="recommend-header">
        <h2 class="recommend-title">本周推荐</h2>
        <span class="recommend-badge">Claude 精选</span>
        <button class="manage-recommend-btn" id="manageRecommendBtn" title="管理推荐">管理</button>
      </div>
      <div class="recommend-strip" id="recommendStrip">
        {recommendMovies.map((movie) => (
          <div class="recommend-card" data-movie-id={movie.id}>
            <a href={`${base}/movies/${movie.id}`} class="recommend-poster">
              <img src={movie.data.poster} alt={movie.data.title} loading="eager" onerror="this.style.display='none'" />
            </a>
            <div class="recommend-info">
              <a href={`${base}/movies/${movie.id}`} class="recommend-name">{movie.data.title}</a>
              <span class="recommend-year">{movie.data.year} · {movie.data.director}</span>
            </div>
            <button
              class="collect-btn"
              data-movie={JSON.stringify({
                id: movie.id,
                title: movie.data.title,
                poster: movie.data.poster,
                year: movie.data.year,
                director: movie.data.director,
                genre: movie.data.genre,
                rating: movie.data.rating || 0,
              })}
              aria-label="收藏"
            >
              <svg class="collect-heart" viewBox="0 0 24 24" width="18" height="18">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="none" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Filters -->
  <div class="movies-filters">
    <!-- Genre Filter -->
    <div class="filter-group">
      <span class="filter-label">类型</span>
      <div class="filter-tabs" id="genreFilter">
        <button class="filter-tab active" data-genre="all">全部</button>
        {allGenres.map((g) => (
          <button class="filter-tab" data-genre={g}>{g}</button>
        ))}
      </div>
    </div>

    <!-- Rating & Popularity Filters -->
    <div class="filter-row">
      <div class="filter-group">
        <span class="filter-label">评分</span>
        <div class="filter-tabs" id="ratingFilter">
          {ratingLevels.map((r) => (
            <button class="filter-tab" class:list={["filter-tab", { active: r.min === 0 }]} data-rating={r.min}>
              {r.label}
            </button>
          ))}
        </div>
      </div>
      <div class="filter-group">
        <span class="filter-label">热度</span>
        <div class="filter-tabs" id="popularityFilter">
          {popularityLevels.map((p) => (
            <button class="filter-tab" class:list={["filter-tab", { active: p.min === 0 }]} data-popularity={p.min}>
              {p.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Active Filter Summary -->
    <div class="filter-summary" id="filterSummary">
      共 <strong id="filterCount">{movies.length}</strong> 部电影
    </div>
  </div>

  <!-- Collection Mode Banner -->
  <div class="collection-banner" id="collectionBanner" style="display:none">
    <span>📂 我的收藏 (<strong id="collectionBannerCount">0</strong> 部)</span>
    <button class="collection-mode-exit" id="collectionModeExit">← 返回全部电影</button>
  </div>

  <!-- Collection Grid (shown only in collection mode, populated by JS) -->
  <div class="movie-grid" id="collectionGrid" style="display:none"></div>

  <!-- Movie Grid -->
  <div class="movie-grid" id="movieGrid">
    {movies.map((movie, i) => (
      <div
        class="movie-card"
        data-genres={movie.data.genre.join(",")}
        data-rating={movie.data.rating || 0}
        data-popularity={movie.data.popularity || 0}
        style={`--card-delay: ${i * 0.04}s`}
      >
        <a href={`${base}/movies/${movie.id}`} class="movie-card-poster">
          <img
            src={movie.data.poster}
            alt={movie.data.title}
            loading="eager"
            onerror="this.style.display='none'"
          />
          <div class="movie-card-overlay">
            <div class="movie-card-rating">
              {movie.data.rating ? movie.data.rating.toFixed(1) : "N/A"}
            </div>
          </div>
          <button
            class="collect-btn"
            data-movie={JSON.stringify({
              id: movie.id,
              title: movie.data.title,
              poster: movie.data.poster,
              year: movie.data.year,
              director: movie.data.director,
              genre: movie.data.genre,
              rating: movie.data.rating || 0,
            })}
            aria-label="收藏"
            onclick="event.preventDefault()"
          >
            <svg class="collect-heart" viewBox="0 0 24 24" width="16" height="16">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="none" stroke="currentColor" stroke-width="1.8"/>
            </svg>
          </button>
        </a>
        <div class="movie-card-info">
          <h3 class="movie-card-title">
            <a href={`${base}/movies/${movie.id}`}>{movie.data.title}</a>
          </h3>
          <div class="movie-card-meta">
            <span>{movie.data.year}</span>
            <span class="meta-dot"></span>
            <span>{movie.data.director}</span>
          </div>
          <div class="movie-card-genres">
            {movie.data.genre.map((g) => (
              <span class="movie-genre-tag">{g}</span>
            ))}
          </div>
        </div>
        {
          (() => {
            const watchSites: string[] = movie.data.watchLinks || [];
            const links = buildWatchUrls(movie.data.title, watchSites);
            return links.length > 0 ? (
              <button
                class="movie-watch-btn"
                data-title={movie.data.title}
                data-links={JSON.stringify(links)}
              >
                观看
              </button>
            ) : null;
          })()
        }
      </div>
    ))}
  </div>

  <!-- Empty State -->
  <div class="movies-empty" id="moviesEmpty" style="display:none">
    <p>没有匹配的电影，试试调整筛选条件</p>
  </div>
</BaseLayout>

<!-- Add Movie Floating Button -->
<button class="add-movie-fab" id="addMovieFab" title="添加电影推荐">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  <span>添加推荐</span>
</button>

<!-- Watch Modal -->
<div class="watch-modal" id="watchModal">
  <div class="watch-modal-backdrop" id="watchModalBackdrop"></div>
  <div class="watch-modal-content">
    <h3 id="watchModalTitle"></h3>
    <div class="watch-modal-links" id="watchModalLinks"></div>
    <button class="watch-modal-close" id="watchModalClose">关闭</button>
  </div>
</div>

<!-- Add Movie Modal -->
<div class="add-modal" id="addModal">
  <div class="add-modal-backdrop" id="addModalBackdrop"></div>
  <div class="add-modal-panel">
    <div class="add-modal-header">
      <h2>添加电影推荐</h2>
      <button class="add-modal-close-btn" id="addModalClose">&times;</button>
    </div>
    <div class="add-modal-body">
      <div class="add-form-grid">
        <div class="add-field add-field-full">
          <label>中文片名 <span class="add-required">*</span></label>
          <input type="text" id="addTitle" placeholder="例如：星际穿越" />
        </div>
        <div class="add-field">
          <label>原名</label>
          <input type="text" id="addOriginalTitle" placeholder="Interstellar" />
        </div>
        <div class="add-field add-field-3">
          <label>年份 <span class="add-required">*</span></label>
          <input type="number" id="addYear" placeholder="2014" min="1900" max="2030" />
        </div>
        <div class="add-field add-field-3">
          <label>导演 <span class="add-required">*</span></label>
          <input type="text" id="addDirector" placeholder="克里斯托弗·诺兰" />
        </div>
        <div class="add-field add-field-3">
          <label>国家</label>
          <input type="text" id="addCountry" placeholder="美国" />
        </div>
      </div>
      <div class="add-field">
        <label>类型 <span class="add-required">*</span>（勾选，可多选）</label>
        <div class="add-genre-checks" id="addGenreChecks">
          {["科幻","剧情","动画","动作","悬疑","犯罪","惊悚","爱情","奇幻","冒险","喜剧","战争","纪录片","恐怖"].map(g => (
            <label class="add-genre-check"><input type="checkbox" value={g} />{g}</label>
          ))}
        </div>
      </div>
      <div class="add-form-grid">
        <div class="add-field add-field-3">
          <label>评分 (0-10)</label>
          <input type="number" id="addRating" placeholder="9.0" min="0" max="10" step="0.1" />
        </div>
        <div class="add-field add-field-3">
          <label>热度 (0-100)</label>
          <input type="number" id="addPopularity" placeholder="90" min="0" max="100" />
        </div>
        <div class="add-field add-field-3">
          <label>海报URL</label>
          <input type="url" id="addPoster" placeholder="https://image.tmdb.org/t/p/w342/xxx.jpg" />
        </div>
      </div>
      <div class="add-field">
        <label>影评 / 推荐理由</label>
        <textarea id="addReview" rows="4" placeholder="写一段推荐理由，会在详情页展示..."></textarea>
      </div>
      <!-- Preview -->
      <div class="add-preview" id="addPreview" style="display:none">
        <h3>生成的 Markdown</h3>
        <pre id="addMarkdown"></pre>
        <div class="add-preview-actions">
          <button class="add-copy-btn" id="addCopyBtn">复制到剪贴板</button>
          <span class="add-copy-hint">复制后发给 Claude 帮你创建文件</span>
        </div>
      </div>
    </div>
    <div class="add-modal-footer">
      <button class="add-submit-btn" id="addSubmitBtn">生成 Markdown</button>
    </div>
  </div>
</div>

<!-- Manage Recommend Modal -->
<div class="add-modal" id="manageModal">
  <div class="add-modal-backdrop" id="manageModalBackdrop"></div>
  <div class="add-modal-panel">
    <div class="add-modal-header">
      <h2>管理本周推荐</h2>
      <button class="add-modal-close-btn" id="manageModalClose">&times;</button>
    </div>
    <div class="add-modal-body">
      <p class="manage-hint">勾选要移除的电影，或添加新电影。完成后点"生成指令"复制给 Claude 执行。</p>
      <div class="manage-current-list" id="manageCurrentList"></div>
      <hr class="manage-divider" />
      <div class="add-field add-field-full">
        <label>快速添加电影</label>
        <div class="manage-quick-add">
          <input type="text" id="manageQuickTitle" placeholder="电影名称" />
          <input type="text" id="manageQuickDirector" placeholder="导演" style="max-width:140px" />
          <input type="number" id="manageQuickYear" placeholder="年份" style="max-width:80px" min="1900" max="2030" />
          <button class="manage-add-btn" id="manageQuickAddBtn">+ 加入</button>
        </div>
      </div>
      <div class="manage-pending-list" id="managePendingList"></div>
      <div class="add-preview" id="managePreview" style="display:none">
        <h3>生成的指令</h3>
        <pre id="manageMarkdown"></pre>
        <div class="add-preview-actions">
          <button class="add-copy-btn" id="manageCopyBtn">复制到剪贴板</button>
          <span class="add-copy-hint">复制后发给 Claude 执行更新</span>
        </div>
      </div>
    </div>
    <div class="add-modal-footer">
      <button class="add-submit-btn" id="manageGenerateBtn">生成指令</button>
    </div>
  </div>
</div>

<script>
  // --- Filter Logic ---
  let activeGenre = "all";
  let activeRating = 0;
  let activePopularity = 0;

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>(".movie-card");
    let count = 0;

    cards.forEach((card) => {
      const genres = card.dataset.genres?.split(",") || [];
      const rating = parseFloat(card.dataset.rating || "0");
      const popularity = parseFloat(card.dataset.popularity || "0");

      const genreMatch = activeGenre === "all" || genres.includes(activeGenre);
      const ratingMatch = rating >= activeRating;
      const popularityMatch = popularity >= activePopularity;

      if (genreMatch && ratingMatch && popularityMatch) {
        card.classList.remove("hidden");
        count++;
      } else {
        card.classList.add("hidden");
      }
    });

    const grid = document.getElementById("movieGrid")!;
    const empty = document.getElementById("moviesEmpty")!;
    const countEl = document.getElementById("filterCount")!;

    grid.style.display = count === 0 ? "none" : "";
    empty.style.display = count === 0 ? "" : "none";
    countEl.textContent = String(count);
  }

  function setActiveTab(groupId: string, btn: HTMLButtonElement) {
    document.querySelectorAll<HTMLButtonElement>(`#${groupId} .filter-tab`).forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");
  }

  document.getElementById("genreFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("genreFilter", btn);
    activeGenre = btn.dataset.genre || "all";
    applyFilters();
  });

  document.getElementById("ratingFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("ratingFilter", btn);
    activeRating = parseFloat(btn.dataset.rating || "0");
    applyFilters();
  });

  document.getElementById("popularityFilter")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-tab");
    if (!btn) return;
    setActiveTab("popularityFilter", btn);
    activePopularity = parseFloat(btn.dataset.popularity || "0");
    applyFilters();
  });

  // --- Watch Modal ---
  function openWatchModal(btn: HTMLButtonElement) {
    const title = btn.dataset.title || "";
    const links = JSON.parse(btn.dataset.links || "[]") as { name: string; url: string }[];

    document.getElementById("watchModalTitle")!.textContent = `观看：${title}`;

    const linksContainer = document.getElementById("watchModalLinks")!;
    linksContainer.innerHTML = links
      .map(
        (l) =>
          `<a href="${l.url}" target="_blank" rel="noopener noreferrer" class="watch-link-btn">${l.name}</a>`
      )
      .join("");

    document.getElementById("watchModal")!.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeWatchModal() {
    document.getElementById("watchModal")!.classList.remove("open");
    document.body.style.overflow = "";
  }

  // Delegate watch button clicks
  document.getElementById("movieGrid")!.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".movie-watch-btn");
    if (btn) {
      e.preventDefault();
      openWatchModal(btn);
    }
  });

  // Modal close handlers
  document.getElementById("watchModalBackdrop")!.addEventListener("click", closeWatchModal);
  document.getElementById("watchModalClose")!.addEventListener("click", closeWatchModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeWatchModal();
  });

  // --- Intersection Observer for lazy card animation ---
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
  );

  document.querySelectorAll(".movie-card").forEach((card) => observer.observe(card));

  // --- Add Movie Modal ---
  const addFab = document.getElementById("addMovieFab")!;
  const addModal = document.getElementById("addModal")!;
  const addBackdrop = document.getElementById("addModalBackdrop")!;
  const addClose = document.getElementById("addModalClose")!;
  const addSubmit = document.getElementById("addSubmitBtn")!;
  const addPreview = document.getElementById("addPreview")!;
  const addMd = document.getElementById("addMarkdown")!;
  const addCopy = document.getElementById("addCopyBtn")!;

  function openAddModal() {
    addModal.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function closeAddModal() {
    addModal.classList.remove("open");
    document.body.style.overflow = "";
  }
  addFab.addEventListener("click", openAddModal);
  addBackdrop.addEventListener("click", closeAddModal);
  addClose.addEventListener("click", closeAddModal);

  addSubmit.addEventListener("click", () => {
    const title = (document.getElementById("addTitle") as HTMLInputElement).value.trim();
    const originalTitle = (document.getElementById("addOriginalTitle") as HTMLInputElement).value.trim();
    const year = (document.getElementById("addYear") as HTMLInputElement).value.trim();
    const director = (document.getElementById("addDirector") as HTMLInputElement).value.trim();
    const country = (document.getElementById("addCountry") as HTMLInputElement).value.trim();
    const rating = (document.getElementById("addRating") as HTMLInputElement).value.trim();
    const popularity = (document.getElementById("addPopularity") as HTMLInputElement).value.trim();
    const poster = (document.getElementById("addPoster") as HTMLInputElement).value.trim();
    const review = (document.getElementById("addReview") as HTMLTextAreaElement).value.trim();
    const genres = Array.from(document.querySelectorAll<HTMLInputElement>("#addGenreChecks input:checked")).map(cb => cb.value);

    if (!title || !year || !director || genres.length === 0) {
      alert("请至少填写片名、年份、导演和类型");
      return;
    }

    const slug = title.toLowerCase().replace(/\s+/g, "-");
    const today = new Date().toISOString().split("T")[0];
    const posterUrl = poster || "https://image.tmdb.org/t/p/w342/placeholder.jpg";

    const md = `---
title: "${title}"
originalTitle: "${originalTitle}"
year: ${year}
director: "${director}"
country: "${country}"
genre: [${genres.map(g => `"${g}"`).join(", ")}]
rating: ${rating || "0"}
popularity: ${parseInt(popularity) || 80}
poster: ${posterUrl}
backdrop: ${posterUrl.replace("/w342/", "/w1280/")}
watchLinks:
  - mini4k
  - ddys
date: ${today}
---

${review || "（待补充推荐理由）"}
`;

    addMd.textContent = md;
    addPreview.style.display = "block";
    addPreview.scrollIntoView({ behavior: "smooth" });
  });

  addCopy.addEventListener("click", async () => {
    const md = addMd.textContent || "";
    await navigator.clipboard.writeText(md);
    addCopy.textContent = "已复制!";
    addCopy.classList.add("copied");
    setTimeout(() => {
      addCopy.textContent = "复制到剪贴板";
      addCopy.classList.remove("copied");
    }, 2000);
  });

  // --- Collection Logic ---
  const COLLECTION_KEY = "movie-collections";

  function getCollections(): any[] {
    try { return JSON.parse(localStorage.getItem(COLLECTION_KEY) || "[]"); }
    catch { return []; }
  }

  function saveCollections(col: any[]) {
    localStorage.setItem(COLLECTION_KEY, JSON.stringify(col));
  }

  function updateCollectButtons() {
    const collections = getCollections();
    const ids = new Set(collections.map((c: any) => c.id));

    document.querySelectorAll<HTMLElement>(".collect-btn").forEach((btn) => {
      const movieData = JSON.parse(btn.dataset.movie || "{}");
      const isCollected = ids.has(movieData.id);
      btn.classList.toggle("collected", isCollected);
    });

    // Update sidebar count
    const countEl = document.getElementById("collectionCount");
    if (countEl) countEl.textContent = String(collections.length);
  }

  // Delegate collect button clicks
  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(".collect-btn");
    if (!btn) return;
    e.preventDefault();
    const movieData = JSON.parse(btn.dataset.movie || "{}");
    const collections = getCollections();
    const idx = collections.findIndex((c: any) => c.id === movieData.id);
    if (idx >= 0) {
      collections.splice(idx, 1);
    } else {
      collections.push({ ...movieData, collectedAt: new Date().toISOString() });
    }
    saveCollections(collections);
    updateCollectButtons();
    applyCollectionView();
  });

  // Collection view mode
  const urlParams = new URLSearchParams(window.location.search);
  let collectionMode = urlParams.get("collection") === "1";

  function renderCollectionGrid(collections: any[]) {
    const grid = document.getElementById("collectionGrid")!;
    const base = import.meta.env.BASE_URL || "/";

    if (collections.length === 0) {
      grid.innerHTML = '<div class=\"movies-empty\"><p>还没有收藏电影，去推荐里发现好片吧</p></div>';
      return;
    }

    // Sync poster URLs from current page data (fixes stale localStorage posters)
    const posterMap: Record<string, string> = {};
    document.querySelectorAll(".collect-btn").forEach((btn) => {
      try {
        const d = JSON.parse((btn as HTMLElement).dataset.movie || "{}");
        if (d.id && d.poster) posterMap[d.id] = d.poster;
      } catch {}
    });

    if (Object.keys(posterMap).length > 0) {
      let updated = false;
      collections = collections.map((c: any) => {
        if (posterMap[c.id] && posterMap[c.id] !== c.poster) {
          updated = true;
          return { ...c, poster: posterMap[c.id] };
        }
        return c;
      });
      if (updated) saveCollections(collections);
    }

    grid.innerHTML = collections.map((c: any) => `
      <div class="movie-card visible" style="--card-delay:0s">
        <a href="${base}movies/${c.id}" class="movie-card-poster">
          <img src="${c.poster}" alt="${c.title}" loading="eager" onerror="this.style.display='none'" />
          <div class="movie-card-overlay">
            <div class="movie-card-rating">${c.rating > 0 ? c.rating.toFixed(1) : 'N/A'}</div>
          </div>
          <button class="collect-btn collected" data-movie='${JSON.stringify(c)}' onclick="event.preventDefault()" aria-label="取消收藏">
            <svg class="collect-heart" viewBox="0 0 24 24" width="16" height="16">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="#ef4444" stroke="#ef4444" stroke-width="1.8"/>
            </svg>
          </button>
        </a>
        <div class="movie-card-info">
          <h3 class="movie-card-title">
            <a href="${base}movies/${c.id}">${c.title}</a>
          </h3>
          <div class="movie-card-meta">
            <span>${c.year}</span>
            <span class="meta-dot"></span>
            <span>${c.director}</span>
          </div>
          <div class="movie-card-genres">
            ${(c.genre || []).map((g: string) => `<span class="movie-genre-tag">${g}</span>`).join("")}
          </div>
        </div>
      </div>
    `).join("");
  }

  function applyCollectionView() {
    const banner = document.getElementById("collectionBanner")!;
    const filters = document.querySelector(".movies-filters") as HTMLElement;
    const fab = document.getElementById("addMovieFab");
    const mainGrid = document.getElementById("movieGrid")!;
    const recommendSection = document.getElementById("recommendSection");
    const collectionGrid = document.getElementById("collectionGrid")!;
    const collections = getCollections();

    if (collectionMode) {
      banner.style.display = "";
      if (filters) filters.style.display = "none";
      if (fab) fab.style.display = "none";
      if (recommendSection) recommendSection.style.display = "none";
      mainGrid.style.display = "none";
      collectionGrid.style.display = "";

      renderCollectionGrid(collections);

      const bannerCount = document.getElementById("collectionBannerCount");
      if (bannerCount) bannerCount.textContent = String(collections.length);
    } else {
      banner.style.display = "none";
      if (filters) filters.style.display = "";
      if (fab) fab.style.display = "";
      if (recommendSection) recommendSection.style.display = "";
      mainGrid.style.display = "";
      collectionGrid.style.display = "none";
      collectionGrid.innerHTML = "";
    }
  }

  document.getElementById("collectionModeExit")?.addEventListener("click", () => {
    collectionMode = false;
    const url = new URL(window.location.href);
    url.searchParams.delete("collection");
    window.history.replaceState({}, "", url.toString());
    applyCollectionView();
    applyFilters();
    updateCollectButtons();
  });

  // Init
  updateCollectButtons();
  if (collectionMode) applyCollectionView();

  // --- Manage Recommend Modal ---
  const manageBtn = document.getElementById("manageRecommendBtn")!;
  const manageModal = document.getElementById("manageModal")!;
  const manageBackdrop = document.getElementById("manageModalBackdrop")!;
  const manageClose = document.getElementById("manageModalClose")!;
  const manageGenerate = document.getElementById("manageGenerateBtn")!;
  const manageCurrentList = document.getElementById("manageCurrentList")!;
  const managePendingList = document.getElementById("managePendingList")!;
  const managePreview = document.getElementById("managePreview")!;
  const manageMd = document.getElementById("manageMarkdown")!;
  const manageCopy = document.getElementById("manageCopyBtn")!;
  const manageQuickAdd = document.getElementById("manageQuickAddBtn")!;

  let pendingAdds: string[] = [];

  function openManageModal() {
    // Populate current recommendations
    const cards = document.querySelectorAll(".recommend-card");
    let html = "";
    cards.forEach((card) => {
      const name = card.querySelector(".recommend-name")?.textContent || "";
      const year = card.querySelector(".recommend-year")?.textContent || "";
      const movieId = (card as HTMLElement).dataset.movieId || "";
      html += '<label class="manage-item"><input type="checkbox" value="' + movieId + '" data-filename="' + movieId.split("/").pop() + '" data-title="' + name + '" /> <span>' + name + '</span> <span class="manage-item-meta">' + year + '</span></label>';
    });
    manageCurrentList.innerHTML = html;
    pendingAdds = [];
    managePendingList.innerHTML = "";
    managePreview.style.display = "none";
    manageModal.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeManageModal() {
    manageModal.classList.remove("open");
    document.body.style.overflow = "";
  }

  manageBtn.addEventListener("click", openManageModal);
  manageBackdrop.addEventListener("click", closeManageModal);
  manageClose.addEventListener("click", closeManageModal);

  manageQuickAdd.addEventListener("click", () => {
    const title = (document.getElementById("manageQuickTitle") as HTMLInputElement).value.trim();
    const director = (document.getElementById("manageQuickDirector") as HTMLInputElement).value.trim();
    const year = (document.getElementById("manageQuickYear") as HTMLInputElement).value.trim();
    if (!title) return;
    const slug = title.toLowerCase().replace(/[^a-z0-9一-鿿]/g, "-").replace(/-+/g, "-").replace(/^-|-$/g, "");
    const entry = `${title} (${director}, ${year})`;
    pendingAdds.push(entry);
    (document.getElementById("manageQuickTitle") as HTMLInputElement).value = "";
    (document.getElementById("manageQuickDirector") as HTMLInputElement).value = "";
    (document.getElementById("manageQuickYear") as HTMLInputElement).value = "";
    renderPending();
  });

  function renderPending() {
    managePendingList.innerHTML = pendingAdds.map((e, i) =>
      '<div class="manage-pending-item"><span>+ ' + e + '</span><button class="manage-remove-pending" data-idx="' + i + '">×</button></div>'
    ).join("");
    document.querySelectorAll(".manage-remove-pending").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const idx = parseInt((e.target as HTMLElement).dataset.idx || "");
        pendingAdds.splice(idx, 1);
        renderPending();
      });
    });
  }

  manageGenerate.addEventListener("click", () => {
    const checked = document.querySelectorAll<HTMLInputElement>("#manageCurrentList input:checked");
    const toRemove: string[] = [];
    checked.forEach((cb) => {
      toRemove.push(`删除推荐: ${cb.dataset.title} (文件: ${cb.dataset.filename})`);
    });

    let cmd = "请帮我更新电影推荐：\n\n";
    if (toRemove.length > 0) {
      cmd += "## 移除以下推荐\n";
      toRemove.forEach((r) => (cmd += `- ${r}\n`));
      cmd += "\n";
    }
    if (pendingAdds.length > 0) {
      cmd += "## 新增以下推荐\n";
      pendingAdds.forEach((a) => (cmd += `- ${a}\n`));
      cmd += "\n";
    }
    if (toRemove.length === 0 && pendingAdds.length === 0) {
      cmd += "（没有变更）\n";
    }

    manageMd.textContent = cmd;
    managePreview.style.display = "block";
    managePreview.scrollIntoView({ behavior: "smooth" });
  });

  manageCopy.addEventListener("click", async () => {
    await navigator.clipboard.writeText(manageMd.textContent || "");
    manageCopy.textContent = "已复制!";
    manageCopy.classList.add("copied");
    setTimeout(() => {
      manageCopy.textContent = "复制到剪贴板";
      manageCopy.classList.remove("copied");
    }, 2000);
  });
</script>

