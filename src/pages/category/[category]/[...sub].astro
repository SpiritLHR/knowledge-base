---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const paths: Array<{ params: { category: string; sub?: string } }> = [];
  const seen = new Set<string>();

  for (const article of articles) {
    if (article.id.startsWith("news/")) continue;
    const parts = article.id.split("/");
    const category = parts[0];
    if (!category) continue;

    const key = category;
    if (!seen.has(key)) {
      seen.add(key);
      paths.push({ params: { category, sub: undefined } });
    }

    if (parts.length > 1) {
      const subPath = parts.slice(0, -1).join("/");
      const subParts = subPath.split("/").slice(1);
      if (subParts.length > 0) {
        const subKey = `${category}/${subParts.join("/")}`;
        if (!seen.has(subKey)) {
          seen.add(subKey);
          paths.push({
            params: { category, sub: subParts.join("/") },
          });
        }
      }
    }
  }

  return paths;
}

const { category, sub } = Astro.params;

const articles = (await getCollection("articles"))
  .filter((a) => !a.id.startsWith("news/"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

let filtered;
if (sub) {
  const targetSub = `${category}/${sub}`;
  filtered = articles.filter((a) => {
    const parts = a.id.split("/");
    const articleSub = parts.slice(0, -1).join("/");
    return parts[0] === category && articleSub === targetSub;
  });
} else {
  filtered = articles.filter((a) => a.id.split("/")[0] === category);
}

const title = sub
  ? `${category} / ${sub.split("/").pop()}`
  : category;
---

<BaseLayout title={`${title} - 米奇妙妙屋`}>
  <header class="content-header">
    <h1>{title}</h1>
    <p class="page-description">
      <a href={`${import.meta.env.BASE_URL}`}>返回全部文章</a>
    </p>
  </header>

  {
    filtered.length === 0 ? (
      <div class="empty-state">
        <p>该分类下暂无文章</p>
      </div>
    ) : (
      <div class="article-list">
        {filtered.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    )
  }
</BaseLayout>
