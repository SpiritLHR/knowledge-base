---
import { getCollection } from "astro:content";
import { getBacklinks } from "../utils/graph";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const allArticles = await getCollection("articles");
const backlinks = getBacklinks(slug, allArticles);
---

{
  backlinks.length > 0 && (
    <section class="backlinks">
      <h3>引用此文章</h3>
      <ul>
        {backlinks.map((article) => (
          <li>
            <a href={`${base}/articles/${article.id}`}>
              {article.data.title}
            </a>
            <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 0.5rem;">
              {article.id.split("/")[0] || ""}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )
}
