---
import Search from "./Search";
import NewsTicker from "./NewsTicker.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");

const tagCount = new Map<string, number>();
const categories = new Map<string, { count: number; subdirs: Set<string> }>();

for (const article of articles) {
  const parts = article.id.split("/");
  const category = parts[0] || "";
  const sub = parts.length > 1 ? parts.slice(0, -1).join("/") : "";

  if (!categories.has(category)) {
    categories.set(category, { count: 0, subdirs: new Set() });
  }
  const cat = categories.get(category)!;
  cat.count++;
  if (sub && sub !== category) cat.subdirs.add(sub);

  for (const tag of article.data.tags || []) {
    tagCount.set(tag, (tagCount.get(tag) || 0) + 1);
  }
}

const searchItems = articles.map((a) => ({
  slug: a.id,
  title: a.data.title,
  description: a.data.description || "",
  category: a.id.split("/")[0] || "",
  tags: a.data.tags || [],
}));

const nameMap: Record<string, string> = {
  programming: "编程语言",
  tools: "工具配置",
  ops: "系统运维",
  reading: "读书笔记",
  thoughts: "日常随想",
};

const sortedTags = Array.from(tagCount.entries()).sort((a, b) => b[1] - a[1]);
const maxTagCount = Math.max(...sortedTags.map(([, c]) => c), 1);
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url?.pathname || "";
---

<aside class="sidebar">
  <div class="sidebar-header">
    <h1><a href="/" style="color: inherit; text-decoration: none;">米奇妙妙屋</a></h1>
    <p>刘鸿儒的个人知识库</p>
  </div>

  <div class="search-container">
    <Search articles={searchItems} client:load />
  </div>

  <div class="sidebar-news">
    <NewsTicker />
  </div>

  <nav class="sidebar-nav">
    <h3>目录</h3>
    <ul>
      <li>
        <a href={`${base}/news`} class:list={[currentPath === `${base}/news` ? "active" : ""]}>
          每日快讯
        </a>
      </li>
      <li>
        <a href={base} class:list={[currentPath === base ? "active" : ""]}>
          全部文章
        </a>
      </li>
      <li>
        <a href={`${base}/graph`} class:list={[currentPath === `${base}/graph` ? "active" : ""]}>
          知识图谱
        </a>
      </li>
      <li>
        <a href={`${base}/tags`} class:list={[currentPath === `${base}/tags` ? "active" : ""]}>
          标签总览
        </a>
      </li>
      {Array.from(categories.keys()).sort().map((cat) => (
        <li>
          <div class="nav-dir">{cat}</div>
          <ul class="nav-sub">
            {Array.from(categories.get(cat)!.subdirs).sort().map((sub) => {
              const rawLabel = sub.split("/").pop() || sub;
              const label = nameMap[rawLabel] || rawLabel;
              return (
                <li>
                  <a href={`${base}/category/${sub}`}>
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar-tags">
    <h3>标签</h3>
    <div class="tag-cloud">
      {sortedTags.slice(0, 30).map(([tag, count]) => {
        const ratio = count / maxTagCount;
        const sizeClass = ratio > 0.7 ? "tag-xl" : ratio > 0.4 ? "tag-lg" : ratio > 0.2 ? "tag-md" : "tag-sm";
        return (
          <a href={`${base}/tags/${tag}`} class={`tag ${sizeClass}`}>
            {tag}
          </a>
        );
      })}
    </div>
  </div>

  <button class="theme-toggle" id="themeToggle" title="切换深色模式">
    <span class="theme-toggle-icon"></span>
  </button>
</aside>

<script>
  const toggle = document.getElementById("themeToggle");
  const html = document.documentElement;
  const saved = localStorage.getItem("theme");
  if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
    html.setAttribute("data-theme", "dark");
  }
  toggle?.addEventListener("click", () => {
    const isDark = html.getAttribute("data-theme") === "dark";
    html.setAttribute("data-theme", isDark ? "light" : "dark");
    localStorage.setItem("theme", isDark ? "light" : "dark");
  });
</script>
